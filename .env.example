# ─── Platform server ─────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
SITE_ORIGIN=https://www.donnasellslv.com

# ─── PostgreSQL (PostGIS + pgvector required) ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/donnasellslv
# Or split:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=donnasellslv
# DB_USER=user
# DB_PASSWORD=password
# DB_SSL=true           # set to "true" on managed DBs (Railway, Render, Supabase)

# ─── RESO Web API (direct MLS feed — requires vendor license from GLVAR) ─────
# Leave RESO_MOCK=true during development — uses db/seed/listings.json instead.
RESO_MOCK=true
RESO_BASE_URL=https://replication.sparkapi.com/Reso/OData
RESO_CLIENT_ID=your_reso_client_id
RESO_CLIENT_SECRET=your_reso_client_secret
# RESO_API_KEY=         # static bearer token alternative

# ─── AI provider ─────────────────────────────────────────────────────────────
# Default: ollama (self-hosted, no API key required)
#   Install: curl -fsSL https://ollama.com/install.sh | sh
#   Models:  ollama pull nomic-embed-text   # embeddings (768-dim)
#            ollama pull llama3.2           # chat / descriptions
#            ollama pull llava              # photo tagging (vision)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# Optional fallback: set AI_PROVIDER=openai to use OpenAI instead of Ollama
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Media / CDN ─────────────────────────────────────────────────────────────
# Default: local disk — photos saved to ./public/media and served at /media
CDN_PROVIDER=local
MEDIA_LOCAL_PATH=public/media
MEDIA_PUBLIC_URL=/media

# MinIO (self-hosted S3 — set CDN_PROVIDER=minio)
# docker run -p 9000:9000 quay.io/minio/minio server /data
# CDN_PROVIDER=minio
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=admin
# MINIO_SECRET_KEY=password
# MINIO_BUCKET=donnasellslv-media
# MINIO_PUBLIC_URL=http://localhost:9000/donnasellslv-media

# Cloudflare R2 (set CDN_PROVIDER=r2)
# CDN_PROVIDER=r2
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=donnasellslv-media
# R2_PUBLIC_URL=https://media.donnasellslv.com

# AWS S3 (set CDN_PROVIDER=s3)
# CDN_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# S3_BUCKET=donnasellslv-media
# S3_PUBLIC_URL=https://media.donnasellslv.com

# ─── Sync scheduler ───────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15         # how often to poll for MLS changes
SYNC_FULL_HOUR=3                 # hour of day (UTC) for full re-sync (0-23)
SYNC_BATCH_SIZE=200              # listings per RESO API page

# ─── Email / notifications ────────────────────────────────────────────────────
# Point this at your own SMTP server / Postfix instance — no Sendgrid required.
SMTP_HOST=localhost
SMTP_PORT=25
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=alerts@donnasellslv.com

# ─── Platform admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@donnasellslv.com
ADMIN_INITIAL_PASSWORD=change_me_immediately

